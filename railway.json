{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn clean package -DskipTests -f backend/pom.xml"
  },
  "deploy": {
    "startCommand": "java -jar backend/target/prospection-radar-*.jar",
    "healthcheckPath": "/api/radar/stats",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
